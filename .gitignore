# KiCad generated outputs (regenerate from source)
hardware/**/gerbers/
hardware/**/fab/
hardware/**/production/
hardware/**/*.gbr
hardware/**/*.drl
hardware/**/*.gbl
hardware/**/*.gtl
hardware/**/*.gbs
hardware/**/*.gts
hardware/**/*.gbo
hardware/**/*.gto
hardware/**/*.gtp
hardware/**/*.gbp

# Keep KiCad source files - these are important
!hardware/**/*.kicad_pcb
!hardware/**/*.kicad_sch
!hardware/**/*.kicad_pro
!hardware/**/*.kicad_sym
!hardware/**/*.kicad_mod
!hardware/**/*.pretty/

