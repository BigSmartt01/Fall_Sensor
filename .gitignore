# Hardware / KiCad
# =========================
# Keep source files, ignore generated outputs
hardware/**/*.bak
hardware/**/*.bak
hardware/**/*-backups/
hardware/**/*.000
hardware/**/*.001
hardware/**/*.002
hardware/**/*.003
hardware/**/*.004
hardware/**/*.005
hardware/**/*.006
hardware/**/*.007
hardware/**/*.008
hardware/**/*.009
hardware/**/_autosave-*
